
!-------------------------------------------------------------------------------
!
!        file name : tubpar.f
!          project : cntgrlib (Carbon Nanotube and Graphite Library)
!         utilized : gcd.f
!     prerequisite : none
!    compatibility : Fortran 77
!
!-------------------------------------------------------------------------------
!
!       subroutine : tubpar
!    last modified : 2004-07-02
!     date created : 2004-05-11
!       created by : Georgii Samsonidze <gsm@mgm.mit.edu>
!      description : structural parameters of nanotubes rolled up from graphene
!
!-------------------------------------------------------------------------------
!
!       tubpar (n,m,l,t,d,theta,tab,phiab,dab,a1t,a1phi,a2t,a2phi,
!               nc,nt,kcx,kcy,ktx,kty)
!
!       input parameters
!
!       integer*4 n,m -- nanotube structural indices
!       real*8    l -- nanotube length [nm]
!
!       output parameters
!
!       real*8    t -- nanotube unit cell length [nm]
!       real*8    d -- nanotube diameter [nm]
!       real*8    theta -- nanotube chiral angle [radian]
!       real*8    tab -- translational distance between A & B atoms [t]
!       real*8    phiab -- circumferential distance between A & B atoms [radian]
!       real*8    dab -- radial distance between A & B atoms [d]
!       real*8    a1t -- translational component of graphene unit vector a1 [t]
!       real*8    a1phi -- circumferential component of a1 vector [radian]
!       real*8    a2t -- translational component of graphene unit vector a2 [t]
!       real*8    a2phi -- circumferential component of a2 vector [radian]
!       integer*4 nc -- number of cutting lines in circumferential direction
!       integer*4 nt -- number of mesh points in translational direction
!       real*8    kcx,kcy -- circumferential quantization wavevector [1/auc]
!       real*8    ktx,kty -- translational quantization wavevector [1/auc]
!
!-------------------------------------------------------------------------------
!
!       tab=(tb-ta)/t & phiab=phib-phia & dab=(db-da)/d & d=(db+da)/2
!
!       parameters (t,d,tab,phiab) need to be optimized, parameters (dab)
!       may also be optimized, parameters (a1t,a1phi,a2t,a2phi) are fixed
!
!-------------------------------------------------------------------------------

	subroutine tubpar (n,m,l,t,d,theta,tab,phiab,dab,a1t,a1phi,a2t,a2phi,nc&
     &,nt,kcx,kcy,ktx,kty)
	implicit none
	integer*4 n,m
	real*8 l
	real*8 t,d,theta,tab,phiab,dab,a1t,a1phi,a2t,a2phi
	integer*4 nc,nt
	real*8 kcx,kcy,ktx,kty
	real*8 pi,sr3
	parameter (pi=+0.3141592653589793d+01,sr3=+0.1732050807568877d+01)
	real*8 acc,auc
	parameter (acc=+0.142d+00,auc=acc*sr3)
	real*8 eps
	parameter (eps=+0.1d-08)
	integer*4 dr,t1,t2
	real*8 r

	if ((n.eq.0.and.m.eq.0).or.l.le.eps) then
	write(*,100)
	stop
	endif
	call gcd (2*n+m,n+2*m,dr)
	t=auc*sr3*dsqrt(dfloat(n*n+n*m+m*m))/dr
	d=auc*dsqrt(dfloat(n*n+n*m+m*m))/pi
	theta=datan(sr3*dfloat(m)/dfloat(2*n+m))
	r=d/2.0d0
	tab=dsin(theta-pi/6.0d0)*acc/t
	phiab=dcos(theta-pi/6.0d0)*acc/r
	dab=0.0d0
	a1t=dsin(theta)*auc/t
	a1phi=dcos(theta)*auc/r
	a2t=dsin(theta-pi/3.0d0)*auc/t
	a2phi=dcos(theta-pi/3.0d0)*auc/r
	nc=2*(n*n+n*m+m*m)/dr
	nt=2*(idint(l/t)/2)
	t1=dfloat((2*m+n)/dr)
	t2=-dfloat((2*n+m)/dr)
	kcx=2.0d0*pi/sr3*(-t2+t1)/dfloat(nc)
	kcy=2.0d0*pi*(-t2-t1)/dfloat(nc)
	ktx=2.0d0*pi/sr3*dfloat(m-n)/dfloat(nc)
	kty=2.0d0*pi*dfloat(m+n)/dfloat(nc)
	ktx=ktx/dfloat(nt)
	kty=kty/dfloat(nt)

	return
100	format(" >> cntgrlib >> tubpar >> out of range >> ")
	end subroutine tubpar

!-------------------------------------------------------------------------------


!-------------------------------------------------------------------------------
!
!        file name : gcd.f
!          project : cntgrlib (Carbon Nanotube and Graphite Library)
!         utilized : none
!     prerequisite : none
!    compatibility : Fortran 77
!
!-------------------------------------------------------------------------------
!
!       subroutine : gcd
!    last modified : 2005-09-26
!     date created : 2002-10-31
!       created by : Georgii G Samsonidze <gsm@mgm.mit.edu>
!      description : returns the greatest common divisor of two integer numbers
!        reference : "Physical Properties of Carbon Nanotubes" by R.Saito,
!        reference : G.Dresselhaus, M.S.Dresselhaus, Imperial College Press
!        reference : (1998) [mgm#s617]
!
!-------------------------------------------------------------------------------
!
!       gcd (n,m,d)
!
!       input parameters
!
!       integer*4 n,m -- two integer numbers
!
!       output parameters
!
!       integer*4 d -- the greatest common divisor of n and m
!
!-------------------------------------------------------------------------------

	subroutine gcd (n,m,d)
	implicit none
	integer*4 n
	integer*4 m
	integer*4 d

	integer*4 i
	integer*4 j
	integer*4 k
	integer*4 l

	i=iabs(n)
	j=iabs(m)
	if (j.gt.i) then
	k=j
	j=i
	i=k
	endif
	if (j.eq.0) then
	l=i
	else
	k=j
	do while (k.ne.0)
	k=mod(i,j)
	if (k.eq.0) then
	l=j
	else
	i=j
	j=k
	endif
	enddo
	endif

	d=l
	return
	end subroutine gcd

!-------------------------------------------------------------------------------

